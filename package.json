{
  "name": "jm-adm",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "build": "pnpm -r build",
    "start": "pnpm -r start",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter web test:e2e:critical",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma generate && prisma db seed && pnpm db:seed:check",
    "db:seed:check": "tsx scripts/seed-check.ts",
    "db:reset": "prisma migrate reset --force",
    "import:demo": "tsx scripts/import-demo.ts",
    "format": "prettier --write \".github/workflows/*.yml\" \"*.{json,md,yml,yaml,cjs}\" \"apps/api/{package.json,tsconfig.json}\" \"apps/web/{package.json,tsconfig.json,playwright.config.ts}\" \"apps/web/tests/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \".github/workflows/*.yml\" \"*.{json,md,yml,yaml,cjs}\" \"apps/api/{package.json,tsconfig.json}\" \"apps/web/{package.json,tsconfig.json,playwright.config.ts}\" \"apps/web/tests/**/*.{ts,tsx}\"",
    "test:e2e:smoke": "pnpm --filter web test:e2e:smoke",
    "test:e2e:real": "pnpm --filter web test:e2e:real",
    "test:e2e:all": "pnpm --filter web test:e2e:all",
    "db:migrate:deploy": "prisma migrate deploy",
    "test:e2e:critical": "pnpm --filter web test:e2e:critical",
    "bootstrap:check": "tsx scripts/bootstrap-check.ts",
    "bootstrap:full": "pnpm db:migrate:deploy && pnpm db:seed && pnpm import:demo && pnpm bootstrap:check",
    "test:dod": "tsx scripts/dod-matrix.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@prisma/client": "5.22.0",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.5.3",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
